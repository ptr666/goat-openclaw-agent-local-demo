# agent-api
PORT=8787

# plugin -> backend base URL
GOATPAY_API_BASE_URL=http://localhost:8787
AGENT_BASE_URL=http://localhost:8787

# payment provider: mock | x402
PAYMENT_PROVIDER=mock

# x402 wiring
GOATX402_API_URL=http://localhost:8286
GOATX402_API_KEY=
GOATX402_AUTH_SCHEME=bearer
GOATX402_API_KEY_HEADER=x-api-key
GOATX402_ORDER_PATH=/api/v1/orders
GOATX402_STATUS_PATH_TEMPLATE=/api/v1/orders/{orderId}
GOATX402_PROOF_PATH_TEMPLATE=/api/v1/orders/{orderId}/proof
GOAT_DEFAULT_FROM_ADDRESS=0x0000000000000000000000000000000000000000
GOAT_TOKEN_DECIMALS=6

# delegate / callback mode
X402_ENABLE_CALLBACK=false
X402_CALLBACK_ADAPTER=0xYourMerchantCallbackAdapter
# Leave empty to auto-build ABI calldata for:
# onX402Callback(bytes32 orderId, address payer, bytes32 actionId, uint256 amount)
# Supported placeholders if you do provide a template:
# {orderId} {actionId} {amount} {amountWei} {userId} {payer} {inputHash} {entitlementKey}
X402_CALLBACK_CALLDATA_TEMPLATE=

# GOAT network / registration wiring
GOAT_CHAIN_ID=48816
GOAT_NETWORK_NAME=GOAT Testnet3
GOAT_RPC_URL=https://rpc.testnet3.goat.network
IDENTITY_REGISTRY=0xYourIdentityRegistry
EXECUTION_RECEIPT=0xYourExecutionReceipt
AGENT_ID=1
REGISTRATION_IMAGE=ipfs://<cid>/agent.png
